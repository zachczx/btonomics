---
import type { GetStaticPaths } from 'astro'
import Layout from '../../layouts/Layout.astro'
import PostCard from '../../components/PostCard.astro'
import SectionHeading from '../../components/SectionHeading.astro'
import { getCollection } from 'astro:content'
import { GetUniqueTags, getRelatedTags } from '../../lib/utils'

export const getStaticPaths = (async () => {
    const entries = await getCollection('blog')
    const tagsList = await GetUniqueTags(entries)

    return tagsList.map((tag) => {
        const filtered = entries
            .filter((entry) => entry.data.tags?.includes(tag))
            .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        const related = getRelatedTags(entries, tag, 6)
        return { params: { tag }, props: { filtered, related } }
    })
}) satisfies GetStaticPaths

const { filtered, related } = Astro.props
const { tag } = Astro.params
---

<Layout
    title={`#${tag}`}
    description={`Browse ${filtered.length} ${filtered.length === 1 ? 'post' : 'posts'} tagged "${tag}" on BTOnomics, covering honest HDB renovation lessons, reviews, shopping, and home maintenance.`}
>
    <div class="mb-10" data-pagefind-ignore>
        <nav class="text-ink/55 mb-5 text-sm">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            <span class="mx-2 opacity-40">/</span>
            <span class="text-ink/80">Tag</span>
        </nav>

        <SectionHeading
            level="h1"
            title={`#${tag}`}
            note={`${filtered.length} ${filtered.length === 1 ? 'post' : 'posts'} tagged`}
            class="mb-0"
        />

        {
            related.length > 0 && (
                <div class="mt-6 flex flex-wrap items-center gap-2">
                    <span class="eyebrow text-ink/40 text-[0.62rem]">Often appears with</span>
                    {related.map((t) => (
                        <a
                            href={`/tag/${t}`}
                            class="border-base-300 text-ink/70 hover:border-secondary hover:text-secondary rounded-full border px-3 py-1 text-sm transition-colors"
                        >
                            {t}
                        </a>
                    ))}
                </div>
            )
        }
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {filtered.map((entry) => <PostCard post={entry} />)}
    </div>
</Layout>
