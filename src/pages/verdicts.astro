---
import Layout from '../layouts/Layout.astro'
import PostGrid from '../components/PostGrid.astro'
import SectionHeading from '../components/SectionHeading.astro'
import { CleanAndSort } from '../lib/utils'
import RatingIcon from '~icons/mingcute/star-fill'

const allPosts = await CleanAndSort()
const rated = allPosts.filter((p) => p.data.rating != null || p.data.verdict)
rated.sort((a, b) => (b.data.rating ?? 0) - (a.data.rating ?? 0))

const withRating = rated.filter((p) => p.data.rating != null)
const avgRating =
    withRating.length > 0
        ? withRating.reduce((sum, p) => sum + (p.data.rating ?? 0), 0) / withRating.length
        : 0
const winCount = rated.filter((p) => p.data.mood === 'positive').length
const failCount = rated.filter((p) => p.data.mood === 'negative').length
---

<Layout
    title="Honest Product & Vendor Verdicts for HDB Homes"
    description="Every product and vendor we put a real rating on, the wins, the regrets, and what we'd actually buy again. No sponsors, no affiliate kickbacks."
>
    <div class="mb-10">
        <SectionHeading level="h1" title="The verdicts" class="mb-4" />
        <p class="text-base-content/65 max-w-2xl text-lg">
            Everything we put a real rating on, the stuff worth your money and the stuff that
            wasn't. No sponsors, no affiliate kickbacks, just our own receipts.
        </p>
        <div
            class="ledger text-base-content/55 mt-6 flex flex-wrap items-baseline gap-x-5 gap-y-1.5 text-sm"
        >
            <span>
                <strong class="text-base-content text-lg font-extrabold">{rated.length}</strong> verdicts
            </span>
            <span class="text-ink/20" aria-hidden="true">·</span>
            <span class="inline-flex items-center gap-1">
                <strong class="text-accent-content text-lg font-extrabold">
                    {avgRating.toFixed(1)}
                </strong>
                avg
                <RatingIcon class="text-accent-content h-4 w-4" aria-hidden="true" />
            </span>
            <span class="text-ink/20" aria-hidden="true">·</span>
            <span>
                <strong class="text-secondary text-lg font-extrabold">{winCount}</strong> wins /
                <strong class="text-primary text-lg font-extrabold">{failCount}</strong> fails
            </span>
        </div>
    </div>

    <PostGrid posts={rated} sortable filterable defaultSort="rating" id="verdicts" />
</Layout>
