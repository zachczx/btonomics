---
import Layout from '../layouts/Layout.astro'
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro'
import SectionHeading from '../components/SectionHeading.astro'
---

<Layout
    title="Search HDB Renovation Guides & Honest Reviews"
    description="Search BTOnomics for honest HDB renovation advice, product and vendor reviews, Taobao shopping tips, maintenance guides, and real costs."
>
    <div class="mb-8">
        <SectionHeading level="h1" title="Search" class="mb-4" />
        <p class="text-ink/65 max-w-xl text-lg">
            Find a post by room, material, brand, or the mistake you're trying not to repeat.
        </p>
    </div>

    <!-- astro-pagefind v2: <pagefind-config> bootstraps the @pagefind/component-ui
         web components; we compose them inline for a full-page search experience. -->
    <PagefindConfig />

    <div class="pf-page mx-auto max-w-2xl">
        <pagefind-input placeholder="Search posts…" autofocus></pagefind-input>
        <pagefind-summary class="pf-page-summary"></pagefind-summary>
        <pagefind-results></pagefind-results>
    </div>
</Layout>

<style is:global>
    /* Theme the Pagefind component UI with our V3 tokens. */
    :root {
        --pf-font: var(--font-body);
        --pf-text: var(--color-ink);
        --pf-text-secondary: color-mix(in oklab, var(--color-ink), white 38%);
        --pf-text-muted: color-mix(in oklab, var(--color-ink), white 55%);
        --pf-background: var(--color-base-100);
        --pf-border: var(--color-base-300);
        --pf-border-focus: var(--color-primary);
        --pf-hover: var(--color-base-200);
        --pf-mark: var(--color-primary);
        --pf-border-radius: 0.8rem;
        --pf-input-height: 3rem;
        --pf-input-font-size: 1.05rem;
        --pf-outline-focus: var(--color-primary);
        --pf-outline-width: 2px;
        --pf-shadow-sm: 0 2px 8px rgba(27, 23, 20, 0.05);
        --pf-shadow-md: 0 6px 18px rgba(27, 23, 20, 0.08);
        --pf-shadow-lg: 0 18px 44px rgba(27, 23, 20, 0.16);
    }

    .pf-page-summary {
        display: block;
        margin-top: 1.5rem;
    }
    /* Result titles in the brand heading face */
    .pf-heading-link {
        font-family: var(--font-heading);
        font-weight: 700;
    }
</style>
