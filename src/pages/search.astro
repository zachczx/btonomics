---
import PagefindSearch from 'astro-pagefind/components/Search.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout title="Search">
    <PagefindSearch
        id="search"
        className="pagefind-ui w-full"
        uiOptions={{ showImages: false, autofocus: true }}
    />
</Layout>

<style is:global>
    .pagefind-ui {
        --pagefind-ui-scale: 1;
        --pagefind-ui-primary: var(--color-primary);
        --pagefind-ui-text: var(--color-base-content);
        --pagefind-ui-background: none;
        --pagefind-ui-border: var(--color-neutral);
        --pagefind-ui-tag: #eeeeee;
        --pagefind-ui-border-width: 2px;
        --pagefind-ui-border-radius: 8px;
        --pagefind-ui-image-border-radius: 8px;
        --pagefind-ui-image-box-ratio: 3 / 2;
        --pagefind-ui-font: 'Nunito Sans', sans-serif;

        min-width: 100% !important;
        & mark {
            background-color: #f4bf50;
            padding: 0.1em 0.5em 0.1em 0.5em;
        }
    }

    .pagefind-ui__result {
        border: 0 !important;
    }

    .pagefind-ui__result-link,
    .pagefind-ui__result-title {
        color: var(--color-primary) !important;
        text-decoration: underline;

        &:hover {
            color: var(--color-accent) !important;
        }
    }

    .pagefind-ui__button {
        border: 0 !important;
    }

    .pagefind-ui .pagefind-ui__result-excerpt {
        color: #d6d6d6;
    }
    .pagefind-ui__search-input {
        border: #d6d6d6 solid 1px !important;
    }

    .pagefind-ui__search-input:active {
        border: #38bdf8 solid 2px !important;
    }
    .pagefind-ui__search-input::placeholder {
        color: #d6d6d6 !important;
        opacity: 0.7 !important;
    }
    .pagefind-ui__search-clear {
        font-weight: bold;
        font-size: 1.2em !important;
    }
</style>
