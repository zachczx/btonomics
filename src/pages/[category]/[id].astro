---
import Layout from '../../layouts/Layout.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import FormattedDate from '../../components/FormattedDate.astro'
import ReviewSummary from '../../components/ReviewSummary.astro'
import PostCard from '../../components/PostCard.astro'
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import Prose from '../../components/Prose.astro'
import { getCategorySlug, getRelatedPosts } from '../../lib/utils'
import { getCategoryBySlug } from '../../data/categories'

export async function getStaticPaths() {
    const blogEntries = await getCollection('blog')

    return blogEntries.map((entry) => ({
        params: {
            category: getCategorySlug(entry.data.category),
            id: entry.data.slug,
        },
        props: { entry },
    }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)
const d = entry.data

const categorySlug = getCategorySlug(d.category)
const categoryName = getCategoryBySlug(categorySlug)?.name ?? d.category

// Rough reading estimate from the raw body (~200 wpm).
const wordCount = entry.body?.trim().split(/\s+/).filter(Boolean).length ?? 0
const readingTime = Math.max(1, Math.round(wordCount / 200))

const relatedPosts = getRelatedPosts(await getCollection('blog'), entry, 3)

const hasReview = !!(
    d.verdict ||
    d.cost ||
    d.rating != null ||
    (d.pros && d.pros.length) ||
    (d.cons && d.cons.length)
)
---

<Layout title={d.title}>
    <div class="mx-auto w-full max-w-[1440px] lg:flex lg:gap-10">
        <main class="bg-base-100 min-w-0 flex-1 rounded-2xl p-5 shadow-sm lg:p-10">
            <!-- Header (single reading measure) -->
            <div class="mx-auto max-w-[44rem]">
                <nav class="text-base-content/70 mb-6 text-sm">
                    <a href="/" class="hover:text-primary transition-colors">Home</a>
                    <span class="mx-2 opacity-40">/</span>
                    <a href={`/${categorySlug}`} class="hover:text-primary transition-colors">
                        {categoryName}
                    </a>
                </nav>

                {
                    d.mood && (
                        <span
                            class={`eyebrow mb-4 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[0.65rem] ${d.mood === 'positive' ? 'bg-success/12 text-success' : d.mood === 'negative' ? 'bg-error/12 text-error' : 'bg-base-200 text-base-content/60'}`}
                        >
                            {d.mood === 'positive'
                                ? 'A win'
                                : d.mood === 'negative'
                                  ? 'A regret'
                                  : 'A lesson'}
                        </span>
                    )
                }

                <h1
                    class="text-base-content font-heading text-4xl leading-[1.08] font-extrabold md:text-5xl"
                >
                    {d.title}
                </h1>

                {
                    d.description && (
                        <p class="text-base-content/65 mt-4 text-lg leading-relaxed">
                            {d.description}
                        </p>
                    )
                }

                <div
                    class="text-base-content/55 ledger mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs"
                >
                    <span>By {d.author}</span>
                    <span class="opacity-40">·</span>
                    <FormattedDate date={d.pubDate} />
                    <span class="opacity-40">·</span>
                    <span>{readingTime} min read</span>
                    {
                        d.updated && (
                            <>
                                <span class="opacity-40">·</span>
                                <span>
                                    updated <FormattedDate date={d.updated} />
                                </span>
                            </>
                        )
                    }
                </div>

                {
                    d.tags && d.tags.length > 0 && (
                        <div class="mt-5 flex flex-wrap gap-2">
                            {d.tags.map((tag) => (
                                <a
                                    href={`/tag/${tag}`}
                                    class="border-base-300 text-base-content/70 hover:border-secondary hover:text-secondary rounded-full border px-3 py-1 text-xs transition-colors"
                                >
                                    {tag}
                                </a>
                            ))}
                        </div>
                    )
                }
            </div>

            <!-- Cover image (breaks wider than the text column) -->
            {
                d.image && (
                    <figure class="mx-auto mt-8 mb-4 max-w-[56rem]">
                        <Image
                            src={d.image}
                            alt={d.title}
                            width={1100}
                            class="max-h-[30rem] w-full rounded-2xl object-cover shadow-sm"
                        />
                    </figure>
                )
            }

            <!-- Verdict receipt + body (single measure) -->
            <div class="mx-auto max-w-[44rem]">
                {
                    headings.length > 1 && (
                        <details class="group border-base-300 bg-base-200/40 mb-8 rounded-2xl border lg:hidden">
                            <summary class="eyebrow text-base-content/60 flex cursor-pointer list-none items-center justify-between px-5 py-3.5 text-[0.7rem] [&::-webkit-details-marker]:hidden">
                                On this page
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="1.1em"
                                    height="1.1em"
                                    viewBox="0 0 24 24"
                                    class="opacity-50 transition-transform group-open:rotate-180"
                                >
                                    <path fill="currentColor" d="m12 15l-5-5h10z" />
                                </svg>
                            </summary>
                            <div class="px-3 pb-3">
                                <TableOfContents headings={headings} />
                            </div>
                        </details>
                    )
                }
                {
                    hasReview && (
                        <ReviewSummary
                            verdict={d.verdict}
                            recommend={d.recommend}
                            rating={d.rating}
                            cost={d.cost}
                            pros={d.pros}
                            cons={d.cons}
                        />
                    )
                }

                {!hasReview && <div class="border-base-300 mt-8 mb-2 border-t" />}

                <article>
                    <Prose>
                        <Content />
                    </Prose>
                </article>

                <p class="border-base-300 text-base-content/50 mt-14 border-t pt-6 text-xs italic">
                    We paid for everything here ourselves, no sponsorships, no affiliate kickbacks.
                    Just our own receipts.
                </p>
            </div>

            <!-- Keep reading -->
            {
                relatedPosts.length > 0 && (
                    <div class="mx-auto mt-16 max-w-[56rem]">
                        <div class="mb-6">
                            <span class="eyebrow text-primary text-[0.7rem]">Keep reading</span>
                            <h2 class="text-base-content font-heading mt-2 text-3xl font-extrabold">
                                More from the diary
                            </h2>
                        </div>
                        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                            {relatedPosts.map((p) => (
                                <PostCard post={p} />
                            ))}
                        </div>
                    </div>
                )
            }
        </main>

        <aside class="hidden shrink-0 lg:block lg:w-72">
            <div class="h-20"></div>
            <div class="sticky top-24">
                <h2 class="eyebrow text-base-content/45 mb-4 pl-4 text-[0.7rem]">On this page</h2>
                <TableOfContents headings={headings} />
            </div>
        </aside>
    </div>
</Layout>
