---
import Layout from '../../layouts/Layout.astro'
import PostGrid from '../../components/PostGrid.astro'
import CategorySwatch from '../../components/CategorySwatch.astro'
import { getCollection } from 'astro:content'
import { categories, getCategoryBySlug } from '../../data/categories'
import { getCategorySlug } from '../../lib/utils'

export async function getStaticPaths() {
    return categories.map((c) => ({ params: { category: c.slug } }))
}

const { category } = Astro.params
const cat = getCategoryBySlug(category!)!

const posts = await getCollection('blog', ({ data }) => getCategorySlug(data.category) === category)
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const others = categories.filter((c) => c.slug !== category)
---

<Layout title={cat.name}>
    <!-- Identity header -->
    <div class="mb-10">
        <nav class="text-ink/55 mb-5 text-sm">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            <span class="mx-2 opacity-40">/</span>
            <span class="text-ink/80">{cat.name}</span>
        </nav>

        <div class="flex items-start gap-4">
            <CategorySwatch color={cat.swatch} class="h-14 w-14 rounded-2xl" />
            <div>
                <div class="flex items-center gap-3">
                    <h1 class="text-ink font-heading text-4xl font-extrabold md:text-5xl">
                        {cat.name}
                    </h1>
                    <span class="eyebrow bg-base-200 text-ink/60 rounded-full px-2.5 py-1">
                        {posts.length}
                        {posts.length === 1 ? 'post' : 'posts'}
                    </span>
                </div>
                <p class="text-ink/65 mt-2 max-w-2xl text-lg">{cat.description}</p>
            </div>
        </div>
    </div>

    <!-- Posts -->
    {
        posts.length > 0 ? (
            <PostGrid posts={posts} sortable={posts.length > 1} id="cat-posts" />
        ) : (
            <div class="border-base-300 bg-base-200 text-ink/55 rounded-2xl border px-6 py-14 text-center">
                Nothing here yet, check back soon.
            </div>
        )
    }

    <!-- Switch category -->
    <div class="border-base-300 mt-16 border-t pt-8">
        <span class="eyebrow text-primary text-[0.7rem]">Keep browsing</span>
        <div class="mt-4 flex flex-wrap gap-3">
            {
                others.map((c) => (
                    <a
                        href={`/${c.slug}`}
                        class="border-base-300 hover:border-ink/30 group inline-flex items-center gap-2.5 rounded-full border px-4 py-2.5 transition-colors"
                    >
                        <CategorySwatch color={c.swatch} class="h-4 w-4 rounded" />
                        <span class="text-ink font-semibold">{c.name}</span>
                    </a>
                ))
            }
        </div>
    </div>
</Layout>
