---
import Layout from '../layouts/Layout.astro'
import PostCard from '../components/PostCard.astro'
import { Image } from 'astro:assets'
import { CleanAndSort } from '../lib/utils'
import vision from '../images/3_concept1_header-topaz-enhance-4x.webp'
import reality from '../images/36_upload_IMG_20180730_204953_header.jpg'
import { categories } from '../data/categories'

import CryingEmoji from '~icons/noto/loudly-crying-face'
import Party from '~icons/noto/party-popper'

const allPosts = await CleanAndSort()
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const latestPosts = allPosts.slice(0, 6)
const regretPost = allPosts.find((post) => post.data.mood === 'negative')
const worthItPost = allPosts.find((post) => post.data.mood === 'positive')

// allPosts came through CleanAndSort(), so data.category is already the slug
const categoryCounts: Record<string, number> = {}
categories.forEach((cat) => {
    categoryCounts[cat.slug] = allPosts.filter((post) => post.data.category === cat.slug).length
})
---

<Layout title="Home" fullBleed>
    <!-- ============ HERO — before / after ============ -->
    <section class="bg-paper relative overflow-hidden">
        <div
            class="blueprint pointer-events-none absolute inset-0 [mask-image:linear-gradient(to_bottom,black,transparent_85%)] opacity-30"
        >
        </div>
        <div
            class="relative container mx-auto grid items-center gap-12 px-4 py-16 md:py-20 lg:grid-cols-2"
        >
            <div>
                <span
                    class="eyebrow border-ink/10 bg-base-100 text-secondary inline-flex items-center gap-2 rounded-full border-2 px-4 py-2 text-[0.66rem]"
                >
                    Bukit Batok · 4-room HDB · since 2018
                </span>
                <h1 class="text-ink mt-5 text-5xl leading-[1.0] font-extrabold md:text-6xl">
                    Renovating a home, <span class="marker">honestly.</span>
                </h1>
                <p class="text-ink/70 mt-5 max-w-md text-lg leading-relaxed">
                    The wins, the regrets, and what each one actually cost — so your first place
                    turns out better than ours did.
                </p>
                <div class="mt-8 flex flex-wrap gap-3">
                    <a
                        href="/blog"
                        class="bg-neutral text-neutral-content rounded-full px-6 py-3 font-semibold transition-transform hover:-translate-y-0.5"
                        >Read the latest</a
                    >
                    <a
                        href="/renovation/our-clean-bto-home-design"
                        class="border-ink/15 text-ink hover:border-ink/40 rounded-full border-2 px-6 py-3 font-semibold transition-colors"
                        >See our home</a
                    >
                </div>
            </div>

            <!-- before / after signature -->
            <div class="relative mx-auto w-full max-w-lg">
                <div class="grid grid-cols-2 gap-4">
                    <figure class="relative">
                        <div
                            class="border-ink/10 bg-base-100 aspect-4/5 overflow-hidden rounded-2xl border-2"
                        >
                            <Image
                                src={vision}
                                alt="The original 3D design concept"
                                width={420}
                                height={525}
                                class="h-full w-full object-cover grayscale"
                                loading="eager"
                            />
                        </div>
                        <span
                            class="eyebrow bg-neutral/90 text-neutral-content absolute top-3 left-3 rounded-full px-2.5 py-1 text-[0.55rem]"
                            >Before · the plan</span
                        >
                    </figure>
                    <figure class="relative">
                        <div
                            class="border-ink/10 bg-base-100 aspect-4/5 overflow-hidden rounded-2xl border-2"
                        >
                            <Image
                                src={reality}
                                alt="Our finished living and dining room"
                                width={420}
                                height={525}
                                class="h-full w-full object-cover"
                                loading="eager"
                            />
                        </div>
                        <span
                            class="eyebrow bg-secondary text-secondary-content absolute top-3 left-3 rounded-full px-2.5 py-1 text-[0.55rem]"
                            >After · the reality</span
                        >
                    </figure>
                </div>
                <div
                    class="bg-neutral text-neutral-content absolute top-1/2 left-1/2 flex h-11 w-11 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full text-xl font-bold shadow-lg"
                >
                    →
                </div>
            </div>
        </div>
    </section>

    <!-- ============ THE HONEST TRUTH ============ -->
    {
        (regretPost || worthItPost) && (
            <section class="bg-base-100 py-16 md:py-20">
                <div class="container mx-auto px-4">
                    <div class="mb-9">
                        <span class="eyebrow text-primary text-[0.7rem]">Receipts don't lie</span>
                        <h2 class="text-ink mt-2 text-4xl font-extrabold">The honest truth</h2>
                    </div>
                    <div class="grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2">
                        {regretPost && (
                            <a
                                href={`/${regretPost.data.category}/${regretPost.data.slug}`}
                                class="group block"
                            >
                                <div class="border-error/25 bg-base-100 hover:border-error overflow-hidden rounded-2xl border-2 transition-all duration-300 hover:-translate-y-1">
                                    {regretPost.data.image && (
                                        <div class="bg-base-200 aspect-video overflow-hidden">
                                            <Image
                                                src={regretPost.data.image}
                                                alt={regretPost.data.title}
                                                width={600}
                                                height={338}
                                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                            />
                                        </div>
                                    )}
                                    <div class="p-5">
                                        <span class="eyebrow bg-error text-error-content inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[0.6rem]">
                                            <CryingEmoji /> Fail
                                        </span>
                                        <h3 class="text-ink group-hover:text-primary mt-3 text-lg font-bold transition-colors">
                                            {regretPost.data.title}
                                        </h3>
                                        <p class="text-ink/55 mt-1 text-sm">
                                            Read the cautionary tale →
                                        </p>
                                    </div>
                                </div>
                            </a>
                        )}
                        {worthItPost && (
                            <a
                                href={`/${worthItPost.data.category}/${worthItPost.data.slug}`}
                                class="group block"
                            >
                                <div class="border-secondary/25 bg-base-100 hover:border-secondary overflow-hidden rounded-2xl border-2 transition-all duration-300 hover:-translate-y-1">
                                    {worthItPost.data.image && (
                                        <div class="bg-base-200 aspect-video overflow-hidden">
                                            <Image
                                                src={worthItPost.data.image}
                                                alt={worthItPost.data.title}
                                                width={600}
                                                height={338}
                                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                            />
                                        </div>
                                    )}
                                    <div class="p-5">
                                        <span class="eyebrow bg-secondary text-secondary-content inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[0.6rem]">
                                            <Party /> Win
                                        </span>
                                        <h3 class="text-ink group-hover:text-secondary mt-3 text-lg font-bold transition-colors">
                                            {worthItPost.data.title}
                                        </h3>
                                        <p class="text-ink/55 mt-1 text-sm">
                                            See why we'd do it again →
                                        </p>
                                    </div>
                                </div>
                            </a>
                        )}
                    </div>
                </div>
            </section>
        )
    }

    <!-- ============ LATEST ============ -->
    <section class="bg-paper py-16 md:py-20">
        <div class="container mx-auto px-4">
            <div class="mb-8 flex flex-wrap items-end justify-between gap-2">
                <div>
                    <span class="eyebrow text-primary text-[0.7rem]">Fresh off the to-do list</span>
                    <h2 class="text-ink mt-2 text-4xl font-extrabold">Latest happenings</h2>
                </div>
                <a
                    href="/blog"
                    class="text-secondary inline-flex items-center gap-1 font-semibold hover:underline"
                    >See all →</a
                >
            </div>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {latestPosts.map((post) => <PostCard post={post} />)}
            </div>
        </div>
    </section>

    <!-- ============ BROWSE BY CATEGORY ============ -->
    <section class="bg-base-100 py-16 md:py-20">
        <div class="container mx-auto px-4">
            <div class="mb-8">
                <span class="eyebrow text-primary text-[0.7rem]">Find your rabbit hole</span>
                <h2 class="text-ink mt-2 text-4xl font-extrabold">Browse by category</h2>
            </div>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                {
                    categories.map((cat) => {
                        const Icon = cat.icon
                        return (
                            <a
                                href={`/${cat.slug}`}
                                class="group border-base-300 hover:border-ink/25 flex flex-col rounded-2xl border p-5 transition-all hover:-translate-y-1 hover:shadow-[0_18px_38px_-22px_rgba(27,23,20,0.35)]"
                            >
                                <span
                                    class={`${cat.tintBg} flex h-11 w-11 items-center justify-center rounded-xl text-xl`}
                                >
                                    <Icon />
                                </span>
                                <span class="font-heading text-ink group-hover:text-primary mt-4 font-bold transition-colors">
                                    {cat.name}
                                </span>
                                <span class="ledger text-ink/45 mt-1 text-xs">
                                    {categoryCounts[cat.slug]} posts
                                </span>
                            </a>
                        )
                    })
                }
            </div>
        </div>
    </section>
</Layout>
