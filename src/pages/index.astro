---
import Layout from '../layouts/Layout.astro'
import PostCard from '../components/PostCard.astro'
import { Image } from 'astro:assets'
import { CleanAndSort } from '../lib/utils'
import vision from '../images/3_concept1_header-topaz-enhance-4x.webp'
import reality from '../images/36_upload_IMG_20180730_204953_header.jpg'
import { categories } from '../data/categories'
import CategorySwatch from '../components/CategorySwatch.astro'
import SectionHeading from '../components/SectionHeading.astro'

const allPosts = await CleanAndSort()
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const latestPosts = allPosts.slice(0, 6)

// Honest-truth picks: prefer posts that actually carry a verdict, by rating extremes,
// so the cards show real receipts (cost + rating) rather than just a title.
const withVerdict = allPosts.filter((p) => p.data.verdict)
const worthItPost =
    withVerdict
        .filter((p) => p.data.mood === 'positive')
        .sort((a, b) => (b.data.rating ?? 0) - (a.data.rating ?? 0))[0] ||
    allPosts.find((p) => p.data.mood === 'positive')
const regretPost =
    withVerdict
        .filter((p) => p.data.mood === 'negative')
        .sort((a, b) => (a.data.rating ?? 5) - (b.data.rating ?? 5))[0] ||
    allPosts.find((p) => p.data.mood === 'negative')

// "Receipts" stats
const postCount = allPosts.length
const verdictCount = withVerdict.length
const winCount = allPosts.filter((p) => p.data.mood === 'positive').length
const failCount = allPosts.filter((p) => p.data.mood === 'negative').length
const startYear = Math.min(...allPosts.map((p) => p.data.pubDate.getFullYear()))
const yearsDocumented = Math.max(1, new Date().getFullYear() - startYear)

// allPosts came through CleanAndSort(), so data.category is already the slug
const categoryCounts: Record<string, number> = {}
categories.forEach((cat) => {
    categoryCounts[cat.slug] = allPosts.filter((post) => post.data.category === cat.slug).length
})
---

<Layout
    title="Honest HDB renovation, with receipts"
    description="A Singapore couple's honest HDB/BTO renovation diary, the wins, the regrets, and what each one actually cost, so your first place turns out better than ours did."
    fullBleed
>
    <!-- ============ HERO, before / after ============ -->
    <section class="bg-paper relative overflow-hidden">
        <div
            class="blueprint pointer-events-none absolute inset-0 [mask-image:linear-gradient(to_bottom,black,transparent_85%)] opacity-30"
        >
        </div>
        <div
            class="relative container mx-auto grid items-center gap-12 px-4 py-16 md:py-20 lg:grid-cols-2"
        >
            <div>
                <span
                    class="eyebrow border-ink/10 bg-base-100 text-secondary inline-flex items-center gap-2 rounded-full border-2 px-4 py-2 text-[0.66rem]"
                >
                    4-room HDB · since {startYear}
                </span>
                <h1 class="text-ink mt-5 text-5xl leading-[1.0] font-extrabold md:text-6xl">
                    Renovating a home, <span class="marker">honestly.</span>
                </h1>
                <p class="text-ink/70 mt-5 max-w-md text-lg leading-relaxed">
                    The wins, the regrets, and what each one actually cost, so your first place
                    turns out better than ours did.
                </p>
                <div class="mt-8 flex flex-wrap gap-3">
                    <a
                        href="/blog"
                        class="bg-neutral text-neutral-content rounded-full px-6 py-3 font-semibold transition-transform hover:-translate-y-0.5"
                        >Read the latest</a
                    >
                    <a
                        href="/renovation/our-clean-bto-home-design"
                        class="border-ink/15 text-ink hover:border-ink/40 rounded-full border-2 px-6 py-3 font-semibold transition-colors"
                        >See our home</a
                    >
                </div>
            </div>

            <!-- before / after signature -->
            <div class="relative mx-auto w-full max-w-lg">
                <div class="grid grid-cols-2 gap-3 sm:gap-4">
                    <figure class="relative">
                        <div
                            class="border-ink/10 bg-base-100 aspect-4/5 overflow-hidden rounded-2xl border-2"
                        >
                            <Image
                                src={vision}
                                alt="The original 3D design concept"
                                width={420}
                                height={525}
                                class="h-full w-full object-cover grayscale"
                                loading="eager"
                            />
                        </div>
                        <span
                            class="eyebrow bg-neutral/90 text-neutral-content absolute top-3 left-3 rounded-full px-2.5 py-1 text-[0.55rem]"
                            >Before · the plan</span
                        >
                    </figure>
                    <figure class="relative">
                        <div
                            class="border-ink/10 bg-base-100 aspect-4/5 overflow-hidden rounded-2xl border-2"
                        >
                            <Image
                                src={reality}
                                alt="Our finished living and dining room"
                                width={420}
                                height={525}
                                class="h-full w-full object-cover"
                                loading="eager"
                            />
                        </div>
                        <span
                            class="eyebrow bg-secondary text-secondary-content absolute top-3 left-3 rounded-full px-2.5 py-1 text-[0.55rem]"
                            >After · the reality</span
                        >
                    </figure>
                </div>
                <div
                    class="bg-neutral text-neutral-content absolute top-1/2 left-1/2 flex h-11 w-11 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full text-xl font-bold shadow-lg"
                >
                    →
                </div>
                <p class="eyebrow text-ink/40 mt-4 text-center text-[0.58rem]">
                    Our actual living room, the 3D render vs. move-in day
                </p>
            </div>
        </div>
    </section>

    <!-- ============ RECEIPTS, warm by-the-numbers strip ============ -->
    <section class="bg-paper border-base-300 border-y">
        <div
            class="container mx-auto flex flex-wrap items-baseline justify-center gap-x-5 gap-y-1.5 px-4 py-5 text-sm sm:gap-x-8"
        >
            <span class="ledger text-ink/55">
                <strong class="text-ink text-lg font-extrabold">{postCount}</strong> posts
            </span>
            <span class="text-ink/20" aria-hidden="true">·</span>
            <span class="ledger text-ink/55">
                <strong class="text-ink text-lg font-extrabold">{yearsDocumented}</strong> years
            </span>
            <span class="text-ink/20" aria-hidden="true">·</span>
            <span class="ledger text-ink/55">
                <strong class="text-ink text-lg font-extrabold">{verdictCount}</strong> honest verdicts
            </span>
            <span class="text-ink/20" aria-hidden="true">·</span>
            <span class="ledger text-ink/55">
                <strong class="text-secondary text-lg font-extrabold">{winCount}</strong> wins /
                <strong class="text-primary text-lg font-extrabold">{failCount}</strong> fails
            </span>
        </div>
    </section>

    <!-- ============ THE HONEST TRUTH ============ -->
    {
        (regretPost || worthItPost) && (
            <section class="bg-base-100 py-16 md:py-20">
                <div class="container mx-auto px-4">
                    <SectionHeading
                        title="The honest truth"
                        note={`${verdictCount} verdicts on record`}
                        action={{ href: '/verdicts', label: 'See all verdicts' }}
                        class="mb-9"
                    />
                    <div class="grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2">
                        {regretPost && (
                            <a
                                href={`/${regretPost.data.category}/${regretPost.data.slug}`}
                                class="group block"
                            >
                                <div class="border-error/25 bg-base-100 hover:border-error h-full overflow-hidden rounded-lg border-2 transition-colors duration-200">
                                    {regretPost.data.image && (
                                        <div class="bg-base-200 aspect-video overflow-hidden">
                                            <Image
                                                src={regretPost.data.image}
                                                alt={regretPost.data.title}
                                                width={600}
                                                height={338}
                                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                            />
                                        </div>
                                    )}
                                    <div class="p-5">
                                        <span class="text-error inline-flex items-center gap-1.5 text-sm font-semibold">
                                            <span class="bg-error h-2.5 w-2.5 rounded-full" />
                                            Fail
                                        </span>
                                        <h3 class="text-ink group-hover:text-primary mt-3 text-lg font-bold transition-colors">
                                            {regretPost.data.title}
                                        </h3>
                                        {regretPost.data.verdict && (
                                            <p class="text-ink/70 mt-2 text-sm leading-snug italic">
                                                “{regretPost.data.verdict}”
                                            </p>
                                        )}
                                        <div class="mt-3 flex flex-wrap items-center gap-3">
                                            {regretPost.data.rating != null && (
                                                <span
                                                    class="flex items-center gap-0.5"
                                                    title={`${regretPost.data.rating} out of 5`}
                                                >
                                                    {[1, 2, 3, 4, 5].map((i) => (
                                                        <span
                                                            class={
                                                                i <=
                                                                Math.round(
                                                                    regretPost.data.rating ?? 0,
                                                                )
                                                                    ? 'text-error text-sm'
                                                                    : 'text-base-300 text-sm'
                                                            }
                                                        >
                                                            ★
                                                        </span>
                                                    ))}
                                                    <span class="ledger text-ink/45 ml-1 text-xs">
                                                        {regretPost.data.rating}/5
                                                    </span>
                                                </span>
                                            )}
                                            {regretPost.data.cost && (
                                                <span class="ledger bg-softmarigold text-accent-content rounded-full px-2.5 py-1 text-xs font-semibold">
                                                    {regretPost.data.cost}
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </a>
                        )}
                        {worthItPost && (
                            <a
                                href={`/${worthItPost.data.category}/${worthItPost.data.slug}`}
                                class="group block"
                            >
                                <div class="border-secondary/25 bg-base-100 hover:border-secondary h-full overflow-hidden rounded-lg border-2 transition-colors duration-200">
                                    {worthItPost.data.image && (
                                        <div class="bg-base-200 aspect-video overflow-hidden">
                                            <Image
                                                src={worthItPost.data.image}
                                                alt={worthItPost.data.title}
                                                width={600}
                                                height={338}
                                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                            />
                                        </div>
                                    )}
                                    <div class="p-5">
                                        <span class="text-secondary inline-flex items-center gap-1.5 text-sm font-semibold">
                                            <span class="bg-secondary h-2.5 w-2.5 rounded-full" />
                                            Win
                                        </span>
                                        <h3 class="text-ink group-hover:text-secondary mt-3 text-lg font-bold transition-colors">
                                            {worthItPost.data.title}
                                        </h3>
                                        {worthItPost.data.verdict && (
                                            <p class="text-ink/70 mt-2 text-sm leading-snug italic">
                                                “{worthItPost.data.verdict}”
                                            </p>
                                        )}
                                        <div class="mt-3 flex flex-wrap items-center gap-3">
                                            {worthItPost.data.rating != null && (
                                                <span
                                                    class="flex items-center gap-0.5"
                                                    title={`${worthItPost.data.rating} out of 5`}
                                                >
                                                    {[1, 2, 3, 4, 5].map((i) => (
                                                        <span
                                                            class={
                                                                i <=
                                                                Math.round(
                                                                    worthItPost.data.rating ?? 0,
                                                                )
                                                                    ? 'text-secondary text-sm'
                                                                    : 'text-base-300 text-sm'
                                                            }
                                                        >
                                                            ★
                                                        </span>
                                                    ))}
                                                    <span class="ledger text-ink/45 ml-1 text-xs">
                                                        {worthItPost.data.rating}/5
                                                    </span>
                                                </span>
                                            )}
                                            {worthItPost.data.cost && (
                                                <span class="ledger bg-softmarigold text-accent-content rounded-full px-2.5 py-1 text-xs font-semibold">
                                                    {worthItPost.data.cost}
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </a>
                        )}
                    </div>
                </div>
            </section>
        )
    }

    <!-- ============ FIND WHAT YOU NEED, search + browse ============ -->
    <section class="bg-paper py-16 md:py-20">
        <div class="container mx-auto px-4">
            <SectionHeading
                title="Search the diary"
                note={`${postCount} posts indexed`}
                class="mb-8"
            />

            <a
                href="/search"
                class="border-base-300 bg-base-100 hover:border-ink/30 group flex items-center gap-3 rounded-full border-2 px-5 py-3.5 transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="1.15em"
                    height="1.15em"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    class="text-ink/40 shrink-0"
                >
                    <circle cx="11" cy="11" r="7"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
                <span class="text-ink/45 truncate"
                    >Search {postCount} posts: vinyl, Taobao, aircon…</span
                >
                <span
                    class="eyebrow bg-neutral text-neutral-content ml-auto hidden shrink-0 rounded-full px-3 py-1 text-[0.6rem] sm:inline"
                    >Search</span
                >
            </a>

            <p class="eyebrow text-ink/40 mt-8 mb-4 text-[0.62rem]">Or jump to a category</p>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                {
                    categories.map((cat) => (
                        <a
                            href={`/${cat.slug}`}
                            class="group border-base-300 hover:border-ink bg-base-100 flex flex-col rounded-lg border p-5 transition-colors"
                        >
                            <CategorySwatch color={cat.swatch} class="h-11 w-11 rounded-xl" />
                            <span class="font-heading text-ink group-hover:text-primary mt-4 font-bold transition-colors">
                                {cat.name}
                            </span>
                            <span class="ledger text-ink/45 mt-1 text-xs">
                                {categoryCounts[cat.slug]} posts
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ============ LATEST ============ -->
    <section class="bg-base-100 py-16 md:py-20">
        <div class="container mx-auto px-4">
            <SectionHeading
                title="Latest happenings"
                note={`${latestPosts.length} most recent`}
                action={{ href: '/blog', label: 'See all' }}
                class="mb-8"
            />
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {latestPosts.map((post) => <PostCard post={post} />)}
            </div>
        </div>
    </section>
</Layout>
