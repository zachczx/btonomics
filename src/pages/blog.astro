---
import Layout from '../layouts/Layout.astro'
import PostCard from '../components/PostCard.astro'
import SectionHeading from '../components/SectionHeading.astro'
import { CleanAndSort } from '../lib/utils'
import type { CollectionEntry } from 'astro:content'

const allPosts = await CleanAndSort()
const postsByCategory = allPosts.reduce((acc: Record<string, CollectionEntry<'blog'>[]>, post) => {
    const category = post.data.category || 'Uncategorized'
    if (!acc[category]) acc[category] = []
    acc[category].push(post)
    return acc
}, {})

const sortedCategories = Object.keys(postsByCategory).sort()
---

<Layout
    title="Blog"
    description="Browse every BTOnomics post about HDB renovation, honest product reviews, budget shopping, home maintenance, and lessons from our 4-room BTO."
>
    <div class="mb-12">
        <SectionHeading
            level="h1"
            title="Every post"
            note={`${allPosts.length} posts and counting`}
            class="mb-4"
        />
        <p class="text-base-content/65 max-w-2xl text-lg">
            The whole renovation diary, wins, regrets, and receipts, sorted by topic.
        </p>
    </div>

    <div class="space-y-16">
        {
            sortedCategories.map((category) => (
                <section>
                    <div class="border-base-300 mb-6 flex items-baseline justify-between border-b pb-3">
                        <h2 class="text-base-content font-heading text-2xl font-bold capitalize md:text-3xl">
                            {category.replace(/-/g, ' ')}
                        </h2>
                        <span class="ledger text-base-content/45 text-xs">
                            {postsByCategory[category].length}
                        </span>
                    </div>
                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                        {postsByCategory[category].map((post) => (
                            <PostCard post={post} />
                        ))}
                    </div>
                </section>
            ))
        }
    </div>
</Layout>
