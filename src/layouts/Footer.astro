---
import { categories } from '../data/categories'
import BackToTopIcon from '~icons/mingcute/arrow-up-line'

const year = new Date().getFullYear()
---

<footer class="bg-neutral text-neutral-content mt-20">
    <div class="container mx-auto px-4 py-14">
        <div class="grid gap-10 md:grid-cols-3">
            <div>
                <div class="flex items-center gap-2.5">
                    <span class="bg-primary block h-3.5 w-3.5 rounded-[4px]"></span>
                    <span class="font-heading text-2xl font-extrabold">BTOnomics</span>
                </div>
                <p class="text-neutral-content/65 mt-4 max-w-xs text-sm leading-relaxed">
                    Honest, slightly-embarrassing lessons from renovating our HDB on a budget.
                </p>
                <p class="eyebrow text-neutral-content/40 mt-4 text-[0.6rem]">
                    4-room HDB · since 2018
                </p>
            </div>

            <div>
                <h3 class="eyebrow text-neutral-content/50 mb-3 text-[0.68rem]">Browse</h3>
                <nav class="flex flex-col gap-2 text-sm">
                    <a href="/" class="text-neutral-content/75 hover:text-primary transition-colors"
                        >Home</a
                    >
                    {
                        categories.map((cat) => (
                            <a
                                href={`/${cat.slug}`}
                                class="text-neutral-content/75 hover:text-primary transition-colors"
                            >
                                {cat.name}
                            </a>
                        ))
                    }
                </nav>
            </div>

            <div>
                <h3 class="eyebrow text-neutral-content/50 mb-3 text-[0.68rem]">More</h3>
                <nav class="flex flex-col gap-2 text-sm">
                    <a
                        href="/blog"
                        class="text-neutral-content/75 hover:text-primary transition-colors"
                        >All posts</a
                    >
                    <a
                        href="/verdicts"
                        class="text-neutral-content/75 hover:text-primary transition-colors"
                        >Verdicts</a
                    >
                    <a
                        href="/about-us"
                        class="text-neutral-content/75 hover:text-primary transition-colors"
                        >About Us</a
                    >
                    <a
                        href="/search"
                        class="text-neutral-content/75 hover:text-primary transition-colors"
                        >Search</a
                    >
                </nav>
            </div>
        </div>

        <div
            class="border-neutral-content/15 mt-12 flex flex-col items-center justify-between gap-4 border-t pt-6 sm:flex-row"
        >
            <div class="text-neutral-content/55 text-xs">
                © {year} Zixian Chen · All rights reserved
            </div>
            <button
                onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
                class="text-neutral-content/80 hover:bg-neutral-content/10 group inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-semibold transition-colors"
                aria-label="Back to top"
            >
                Back to top
                <BackToTopIcon
                    class="h-4 w-4 transition-transform group-hover:-translate-y-1"
                    aria-hidden="true"
                />
            </button>
        </div>
    </div>
</footer>
