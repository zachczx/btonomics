---
const year = new Date().getFullYear()
---

<footer class="bg-forest text-forest-content mt-24">
    <div class="mx-auto max-w-7xl px-4 py-14 md:px-8">
        <div class="grid gap-10 md:grid-cols-3">
            <!-- Brand -->
            <div class="space-y-3">
                <div class="font-serif text-2xl font-extrabold">BTOnomics</div>
                <p class="text-forest-content/70 max-w-xs text-sm">
                    Honest, slightly-embarrassing lessons from renovating our HDB on a budget.
                </p>
                <p class="eyebrow text-forest-content/45 text-[0.6rem]">
                    Est. 2018 · Bukit Batok · 4-room HDB
                </p>
            </div>

            <!-- Browse -->
            <div class="space-y-3">
                <h3 class="eyebrow text-forest-content/55 text-[0.7rem]">Browse</h3>
                <nav class="flex flex-col space-y-2 text-sm">
                    <a href="/" class="text-forest-content/75 hover:text-secondary transition-colors"
                        >Home</a
                    >
                    <a
                        href="/honest-reviews"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >Honest Reviews</a
                    >
                    <a
                        href="/renovation"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >Renovation</a
                    >
                    <a
                        href="/shopping"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >Shopping</a
                    >
                    <a
                        href="/maintenance"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >Maintenance</a
                    >
                    <a
                        href="/general"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >General</a
                    >
                </nav>
            </div>

            <!-- More -->
            <div class="space-y-3">
                <h3 class="eyebrow text-forest-content/55 text-[0.7rem]">More</h3>
                <nav class="flex flex-col space-y-2 text-sm">
                    <a
                        href="/about-us"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >About Us</a
                    >
                    <a
                        href="/search"
                        class="text-forest-content/75 hover:text-secondary transition-colors"
                        >Search</a
                    >
                </nav>
            </div>
        </div>

        <div class="border-forest-content/15 mt-12 border-t pt-6">
            <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
                <div class="ledger text-forest-content/55 text-xs">
                    © {year} Zixian Chen · All rights reserved
                </div>
                <button
                    onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
                    class="eyebrow border-forest-content/25 text-forest-content/80 hover:border-secondary hover:text-secondary group flex items-center gap-1.5 rounded-full border px-4 py-2 text-[0.65rem] transition-colors"
                    aria-label="Back to top"
                >
                    <span>Back to top</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="1em"
                        height="1em"
                        viewBox="0 0 24 24"
                        class="transition-transform group-hover:-translate-y-1"
                    >
                        <path fill="currentColor" d="m12 10.8l-4.6 4.6L6 14l6-6l6 6l-1.4 1.4z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</footer>
