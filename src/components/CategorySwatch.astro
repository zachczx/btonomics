---
// A paint-chip swatch standing in for the old category icons: a solid colour
// block with a darker band along the bottom, like a real paint sample card.
interface Props {
    color: string
    /** sizing / radius classes for the chip */
    class?: string
}
const { color, class: className = 'h-11 w-11 rounded-lg' } = Astro.props
---

<span
    class:list={['relative inline-block shrink-0 overflow-hidden', className]}
    style={`background-color:${color}`}
    aria-hidden="true"
>
    <span class="absolute inset-x-0 bottom-0 h-1/3 bg-black/15"></span>
</span>
