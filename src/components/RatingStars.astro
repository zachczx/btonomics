---
import StarFilled from '~icons/mingcute/star-fill'
import StarEmpty from '~icons/mingcute/star-line'

interface Props {
    rating: number
    tone?: 'primary' | 'secondary' | 'accent'
    class?: string
}

const { rating, tone = 'secondary', class: className } = Astro.props
const roundedRating = Math.round(rating)
const stars = [1, 2, 3, 4, 5].map((position) => position <= roundedRating)
const filledTone = {
    primary: 'text-primary',
    secondary: 'text-secondary',
    accent: 'text-accent-content',
}[tone]
---

<span
    class:list={['inline-flex items-center gap-0.5', className]}
    role="img"
    aria-label={`${rating} out of 5 stars`}
>
    {
        stars.map((filled) =>
            filled ? (
                <StarFilled class={`h-3.5 w-3.5 ${filledTone}`} aria-hidden="true" />
            ) : (
                <StarEmpty class="text-base-300 h-3.5 w-3.5" aria-hidden="true" />
            ),
        )
    }
</span>
