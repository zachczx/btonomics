---

---

<header
    class="border-base-300 bg-paper/85 sticky top-0 z-50 border-b backdrop-blur-md"
    id="main-navbar"
>
    <nav class="container mx-auto flex items-center justify-between gap-4 px-4 py-3.5">
        <a href="/" class="flex items-center gap-2.5">
            <span class="bg-primary block h-3.5 w-3.5 rounded-[4px]"></span>
            <span class="font-heading text-ink text-2xl font-extrabold tracking-tight"
                >BTOnomics</span
            >
        </a>

        <div class="hidden items-center gap-1 lg:flex">
            <a
                href="/blog"
                class="text-ink/75 hover:bg-softcoral hover:text-primary rounded-full px-4 py-2 font-semibold transition-colors"
                >Blog</a
            >
            <a
                href="/about-us"
                class="text-ink/75 hover:bg-softcoral hover:text-primary rounded-full px-4 py-2 font-semibold transition-colors"
                >About</a
            >
            <a
                href="/search"
                class="bg-neutral text-neutral-content ml-1 inline-flex items-center gap-2 rounded-full px-4 py-2 font-semibold transition-transform hover:-translate-y-0.5"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="1em"
                    height="1em"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                >
                    <circle cx="11" cy="11" r="7"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
                Search
            </a>
        </div>

        <div class="dropdown dropdown-end lg:hidden">
            <div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Menu">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </div>
            <ul
                tabindex="0"
                class="menu menu-sm dropdown-content border-base-300 bg-base-100 rounded-box z-[1] mt-3 w-44 border p-2 shadow-lg"
            >
                <li><a href="/blog">Blog</a></li>
                <li><a href="/search">Search</a></li>
                <li><a href="/about-us">About</a></li>
            </ul>
        </div>
    </nav>
</header>
