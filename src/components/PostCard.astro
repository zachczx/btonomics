---
import { Image } from 'astro:assets'
import dayjs from 'dayjs'
import relativeTime from 'dayjs/plugin/relativeTime'
import type { CollectionEntry } from 'astro:content'
import { getCategorySlug } from '../lib/utils'
import Party from '~icons/noto/party-popper'
import CryingEmoji from '~icons/noto/loudly-crying-face'

dayjs.extend(relativeTime)

interface Props {
    post: CollectionEntry<'blog'>
}
const { post } = Astro.props
const d = post.data
const href = `/${getCategorySlug(d.category)}/${d.slug || post.id}`
---

<article class="group">
    <a href={href} class="block">
        <div
            class="bg-base-100 border-base-300 overflow-hidden rounded-2xl border transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_38px_-22px_rgba(27,23,20,0.35)]"
        >
            <div class="bg-base-200 relative aspect-4/3 overflow-hidden">
                {
                    d.image ? (
                        <Image
                            src={d.image}
                            alt={d.title}
                            width={600}
                            height={450}
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                    ) : (
                        <div class="bg-softteal flex h-full w-full items-center justify-center">
                            <span class="eyebrow text-secondary/70 text-xs">
                                {d.tags?.[0] || d.category}
                            </span>
                        </div>
                    )
                }
                {
                    d.mood && (
                        <span
                            class={`eyebrow absolute top-3 left-3 inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[0.55rem] shadow-sm ${d.mood === 'positive' ? 'bg-secondary text-secondary-content' : 'bg-error text-error-content'}`}
                        >
                            {d.mood === 'positive' ? (
                                <>
                                    <Party /> Win
                                </>
                            ) : (
                                <>
                                    <CryingEmoji /> Fail
                                </>
                            )}
                        </span>
                    )
                }
            </div>
            <div class="p-5">
                <div class="flex items-center gap-2">
                    <span
                        class="eyebrow bg-softteal text-secondary rounded-full px-2.5 py-1 text-[0.56rem]"
                        >{d.tags?.[0] || 'Post'}</span
                    >
                    <span class="ledger text-ink/45 ml-auto text-xs"
                        >{dayjs(d.pubDate).fromNow()}</span
                    >
                </div>
                <h3
                    class="font-heading text-ink group-hover:text-primary mt-2.5 text-lg leading-snug font-bold transition-colors"
                >
                    {d.title}
                </h3>
                {
                    d.cost && (
                        <div class="ledger bg-softmarigold text-accent-content mt-3 inline-block rounded-full px-2.5 py-1 text-xs font-semibold">
                            {d.cost}
                        </div>
                    )
                }
            </div>
        </div>
    </a>
</article>
