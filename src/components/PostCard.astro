---
import { Image } from 'astro:assets'
import dayjs from 'dayjs'
import relativeTime from 'dayjs/plugin/relativeTime'
import type { CollectionEntry } from 'astro:content'
import { getCategorySlug } from '../lib/utils'

dayjs.extend(relativeTime)

interface Props {
    post: CollectionEntry<'blog'>
}
const { post } = Astro.props
const d = post.data
const href = `/${getCategorySlug(d.category)}/${d.slug || post.id}`
---

<article
    class="group"
    data-date={d.pubDate.valueOf()}
    data-rating={d.rating ?? ''}
    data-mood={d.mood ?? ''}
>
    <a href={href} class="block">
        <div
            class="bg-base-100 border-base-300 hover:border-ink overflow-hidden rounded-lg border transition-colors duration-200"
        >
            <div class="bg-base-200 aspect-4/3 overflow-hidden">
                {
                    d.image ? (
                        <Image
                            src={d.image}
                            alt={d.title}
                            width={600}
                            height={450}
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                    ) : (
                        <div class="bg-softteal flex h-full w-full items-center justify-center">
                            <span class="eyebrow text-secondary/70 text-xs">
                                {d.tags?.[0] || d.category}
                            </span>
                        </div>
                    )
                }
            </div>
            <div class="p-5">
                <div class="flex items-center gap-2">
                    {
                        d.mood ? (
                            <span
                                class={`inline-flex items-center gap-1.5 text-xs font-semibold ${d.mood === 'positive' ? 'text-secondary' : 'text-error'}`}
                            >
                                <span
                                    class={`h-2 w-2 rounded-full ${d.mood === 'positive' ? 'bg-secondary' : 'bg-error'}`}
                                />
                                {d.mood === 'positive' ? 'Win' : 'Fail'}
                            </span>
                        ) : (
                            <span class="eyebrow bg-softteal text-secondary rounded-full px-2.5 py-1 text-[0.56rem]">
                                {d.tags?.[0] || 'Post'}
                            </span>
                        )
                    }
                    <span class="ledger text-ink/45 ml-auto text-xs"
                        >{dayjs(d.pubDate).fromNow()}</span
                    >
                </div>
                <h3
                    class="font-heading text-ink group-hover:text-primary mt-2.5 text-lg leading-snug font-bold transition-colors"
                >
                    {d.title}
                </h3>
                {
                    d.cost && (
                        <div class="ledger bg-softmarigold text-accent-content mt-3 inline-block rounded-full px-2.5 py-1 text-xs font-semibold">
                            {d.cost}
                        </div>
                    )
                }
            </div>
        </div>
    </a>
</article>
