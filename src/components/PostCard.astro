---
import { Image } from 'astro:assets'
import dayjs from 'dayjs'
import relativeTime from 'dayjs/plugin/relativeTime'
import type { CollectionEntry } from 'astro:content'
import { getCategorySlug } from '../lib/utils'

dayjs.extend(relativeTime)

interface Props {
    post: CollectionEntry<'blog'>
}
const { post } = Astro.props
const d = post.data
const href = `/${getCategorySlug(d.category)}/${d.slug || post.id}`
---

<article class="group">
    <a href={href} class="block">
        <div
            class="bg-base-100 border-base-200 overflow-hidden rounded-lg border shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
        >
            <div class="bg-base-200 aspect-4/3 overflow-hidden">
                {
                    d.image ? (
                        <Image
                            src={d.image}
                            alt={d.title}
                            width={600}
                            height={450}
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                    ) : (
                        <div class="bg-sagetint flex h-full w-full items-center justify-center">
                            <span class="eyebrow text-primary/40 text-xs">
                                {d.tags?.[0] || d.category}
                            </span>
                        </div>
                    )
                }
            </div>
            <div class="p-5">
                <div class="mb-2 flex items-center gap-2">
                    <span class="eyebrow text-secondary text-[0.6rem]">{d.tags?.[0] || 'Post'}</span>
                    <span class="bg-base-300 h-px flex-1"></span>
                    <span class="ledger text-base-content/45 text-[0.7rem]"
                        >{dayjs(d.pubDate).fromNow()}</span
                    >
                </div>
                <h3
                    class="text-base-content group-hover:text-primary font-serif text-lg leading-snug font-bold transition-colors"
                >
                    {d.title}
                </h3>
                {
                    d.cost && (
                        <div class="ledger text-base-content/55 mt-2 text-xs">
                            <span class="text-success">●</span> {d.cost}
                        </div>
                    )
                }
            </div>
        </div>
    </a>
</article>
