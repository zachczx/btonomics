---
import RatingStars from './RatingStars.astro'
import RecommendYesIcon from '~icons/mingcute/check-circle-fill'
import RecommendNoIcon from '~icons/mingcute/close-circle-fill'
import RecommendMaybeIcon from '~icons/mingcute/question-fill'
import ProIcon from '~icons/mingcute/add-circle-fill'
import ConIcon from '~icons/mingcute/minus-circle-fill'

interface Props {
    verdict?: string
    recommend?: 'yes' | 'no' | 'maybe'
    rating?: number
    cost?: string
    pros?: string[]
    cons?: string[]
}
const { verdict, recommend, rating, cost, pros = [], cons = [] } = Astro.props

const recMap = {
    yes: { label: 'Would do again', tint: 'bg-softteal text-secondary', icon: RecommendYesIcon },
    no: { label: 'Would skip', tint: 'bg-softcoral text-primary', icon: RecommendNoIcon },
    maybe: {
        label: 'It depends',
        tint: 'bg-softmarigold text-accent-content',
        icon: RecommendMaybeIcon,
    },
} as const
const rec = recommend ? recMap[recommend] : null
const RecommendationIcon = rec?.icon
const hasFigures = !!cost || !!rec
const hasLists = pros.length > 0 || cons.length > 0
---

<aside class="not-prose my-10">
    <div class="border-base-300 bg-base-200 overflow-hidden rounded-lg border">
        <!-- header: label + star rating -->
        <div class="border-base-300 flex items-center justify-between gap-3 border-b px-5 py-4">
            <span class="eyebrow text-primary text-[0.7rem]">The verdict</span>
            {
                rating != null && (
                    <span class="flex items-center gap-1.5" title={`${rating} out of 5`}>
                        <RatingStars rating={rating} />
                        <span class="ledger text-ink/50 text-xs font-semibold">{rating}/5</span>
                    </span>
                )
            }
        </div>

        <div class="space-y-5 px-5 py-5">
            {
                verdict && (
                    <p class="font-heading text-ink text-2xl leading-snug font-bold">“{verdict}”</p>
                )
            }

            {
                hasFigures && (
                    <div class="flex flex-wrap gap-3">
                        {cost && (
                            <div class="bg-softmarigold rounded-xl px-4 py-3">
                                <span class="eyebrow text-accent-content/55 block text-[0.58rem]">
                                    What it cost
                                </span>
                                <span class="ledger text-ink mt-0.5 block text-lg font-bold">
                                    {cost}
                                </span>
                            </div>
                        )}
                        {rec && (
                            <div class={`rounded-xl px-4 py-3 ${rec.tint}`}>
                                <span class="eyebrow block text-[0.58rem] opacity-65">
                                    The call
                                </span>
                                <span class="mt-0.5 flex items-center gap-1.5 text-lg font-bold">
                                    {RecommendationIcon && (
                                        <RecommendationIcon
                                            class="h-5 w-5 shrink-0"
                                            aria-hidden="true"
                                        />
                                    )}
                                    {rec.label}
                                </span>
                            </div>
                        )}
                    </div>
                )
            }

            {
                hasLists && (
                    <div class="border-base-300 grid gap-5 border-t pt-5 sm:grid-cols-2">
                        {pros.length > 0 && (
                            <div>
                                <span class="eyebrow text-secondary text-[0.65rem]">
                                    What we loved
                                </span>
                                <ul class="mt-2.5 space-y-2">
                                    {pros.map((p) => (
                                        <li class="text-ink/80 flex gap-2.5 text-sm leading-snug">
                                            <ProIcon
                                                class="text-secondary mt-0.5 h-4 w-4 shrink-0"
                                                aria-hidden="true"
                                            />
                                            <span>{p}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                        {cons.length > 0 && (
                            <div>
                                <span class="eyebrow text-primary text-[0.65rem]">
                                    What bugged us
                                </span>
                                <ul class="mt-2.5 space-y-2">
                                    {cons.map((c) => (
                                        <li class="text-ink/80 flex gap-2.5 text-sm leading-snug">
                                            <ConIcon
                                                class="text-primary mt-0.5 h-4 w-4 shrink-0"
                                                aria-hidden="true"
                                            />
                                            <span>{c}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                    </div>
                )
            }
        </div>
    </div>
</aside>
