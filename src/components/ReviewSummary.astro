---
interface Props {
    verdict?: string
    recommend?: 'yes' | 'no' | 'maybe'
    rating?: number
    cost?: string
    pros?: string[]
    cons?: string[]
}
const { verdict, recommend, rating, cost, pros = [], cons = [] } = Astro.props

const recMap = {
    yes: { label: 'Would do again', cls: 'text-success', icon: '✓' },
    no: { label: 'Would skip', cls: 'text-error', icon: '✕' },
    maybe: { label: 'It depends', cls: 'text-warning', icon: '~' },
} as const
const rec = recommend ? recMap[recommend] : null
const hasFigures = !!cost || !!rec
const hasLists = pros.length > 0 || cons.length > 0
---

<aside class="not-prose border-base-300 bg-base-200/60 my-10 overflow-hidden rounded-lg border shadow-sm">
    <!-- receipt header -->
    <div class="border-base-300 flex items-center justify-between border-b border-dashed px-5 py-3">
        <span class="eyebrow text-secondary text-[0.7rem]">The verdict</span>
        {
            rating != null && (
                <span class="flex items-center gap-1" title={`${rating} out of 5`}>
                    {[1, 2, 3, 4, 5].map((i) => (
                        <span
                            class={
                                i <= Math.round(rating)
                                    ? 'text-secondary text-xs'
                                    : 'text-base-content/20 text-xs'
                            }
                        >
                            ●
                        </span>
                    ))}
                    <span class="ledger text-base-content/45 ml-1 text-xs">{rating}/5</span>
                </span>
            )
        }
    </div>

    <div class="space-y-4 px-5 py-4">
        {
            verdict && (
                <p class="text-base-content font-serif text-xl leading-snug font-medium">
                    “{verdict}”
                </p>
            )
        }

        {
            hasFigures && (
                <div class="flex flex-wrap items-end gap-x-8 gap-y-3">
                    {cost && (
                        <div>
                            <span class="eyebrow text-base-content/45 block text-[0.6rem]">
                                What it cost
                            </span>
                            <span class="ledger text-base-content text-xl font-bold">{cost}</span>
                        </div>
                    )}
                    {rec && (
                        <div>
                            <span class="eyebrow text-base-content/45 block text-[0.6rem]">
                                The call
                            </span>
                            <span class={`ledger text-xl font-bold ${rec.cls}`}>
                                {rec.icon} {rec.label}
                            </span>
                        </div>
                    )}
                </div>
            )
        }

        {
            hasLists && (
                <div class="border-base-300 grid gap-5 border-t border-dashed pt-4 sm:grid-cols-2">
                    {pros.length > 0 && (
                        <div>
                            <span class="eyebrow text-success text-[0.65rem]">The good</span>
                            <ul class="mt-2 space-y-1.5">
                                {pros.map((p) => (
                                    <li class="text-base-content/80 flex gap-2 text-sm leading-snug">
                                        <span class="text-success font-bold">+</span>
                                        <span>{p}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )}
                    {cons.length > 0 && (
                        <div>
                            <span class="eyebrow text-error text-[0.65rem]">The bad</span>
                            <ul class="mt-2 space-y-1.5">
                                {cons.map((c) => (
                                    <li class="text-base-content/80 flex gap-2 text-sm leading-snug">
                                        <span class="text-error font-bold">–</span>
                                        <span>{c}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )}
                </div>
            )
        }
    </div>
</aside>
