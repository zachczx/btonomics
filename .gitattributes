# Normalize line endings: text files are stored and checked out as LF.
# Fixes Windows CRLF working-tree files showing as permanently "modified".
* text=auto eol=lf

# Binary assets — never touch their bytes / line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
*.wasm binary
*.pagefind binary

# Explicitly text (kept LF)
*.svg text eol=lf
